  "keyFeatures": [
    "Beautify JavaScript, CSS, and HTML from CLI, Node.js library, Python library, or web browser",
    "Highly configurable with dozens of options for indentation, brace style, line wrapping, and more",
    "Supports .jsbeautifyrc config files and EditorConfig for project-level settings",
    "Language-specific option overrides within a single config file",
    "In-source directives to preserve or ignore specific code sections",
    "Supports template languages including Django, ERB, Handlebars, PHP, Smarty, and Angular",
    "Unpacks scripts packed by Dean Edwards' packer and partially deobfuscates obfuscated scripts",
    "Available via npm, PyPI, and CDN"
  ],
  "publicApiSurface": [
